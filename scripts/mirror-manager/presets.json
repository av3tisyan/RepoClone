{
  "_comment": "Repo catalog for mirror-manager. Each preset expands into apt-mirror 'deb'/'clean' lines plus a GPG key. Suites/components/keys here were verified against upstream. key.kind: 'url' = curl + dearmor-if-armored; 'archive' = Debian/Ubuntu archive keyring (populate-mirror-keys.sh). Keep in sync with config/mirror.list. arch: use 'amd64,all' when the repo's Release lists the 'all' architecture.",
  "presets": [
    {
      "id": "debian",
      "label": "Debian (bookworm + trixie)",
      "category": "Base OS",
      "homepage": "https://www.debian.org/",
      "notes": "Base OS. Key is the Debian archive keyring (run populate-mirror-keys.sh).",
      "key": { "name": "debian-archive-keyring.gpg", "kind": "archive" },
      "entries": [
        { "base_url": "http://deb.debian.org/debian", "suites": ["bookworm", "bookworm-updates", "trixie", "trixie-updates"], "components": ["main", "contrib", "non-free", "non-free-firmware"], "arch": "amd64" },
        { "base_url": "http://security.debian.org/debian-security", "suites": ["bookworm-security", "trixie-security"], "components": ["main", "contrib", "non-free", "non-free-firmware"], "arch": "amd64" }
      ],
      "clean": ["http://deb.debian.org/debian", "http://security.debian.org/debian-security"]
    },
